#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Start Up Batch script
#
# Required ENV vars:
# ------------------
#   JAVA_HOME - location of a JDK home dir
#
# ----------------------------------------------------------------------------

MAVEN_HOME=""

# find maven home
if [ -z "$MAVEN_HOME" ]; then
  MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.6"
fi

if [ ! -d "$MAVEN_HOME" ]; then
  echo "Downloading Maven 3.9.6..."
  mkdir -p "$MAVEN_HOME"
  MAVEN_URL="https://dlcdn.apache.org/maven/maven-3/3.9.6/binaries/apache-maven-3.9.6-bin.zip"
  MAVEN_ZIP="$HOME/.m2/wrapper/apache-maven-3.9.6-bin.zip"
  curl -sL "$MAVEN_URL" -o "$MAVEN_ZIP" 2>&1
  if [ -f "$MAVEN_ZIP" ] && [ -s "$MAVEN_ZIP" ]; then
    unzip -q "$MAVEN_ZIP" -d "$HOME/.m2/wrapper/dists/" 2>/dev/null
    echo "Maven downloaded and extracted"
  else
    echo "Failed to download Maven"
    exit 1
  fi
fi

# Find actual maven home (versioned dir)
MVN_CMD=$(find "$HOME/.m2/wrapper/dists/" -name "mvn" -type f 2>/dev/null | head -1)
if [ -z "$MVN_CMD" ]; then
  echo "Maven binary not found"
  exit 1
fi

# Set JAVA_HOME if not set
if [ -z "$JAVA_HOME" ]; then
  export JAVA_HOME="C:/Program Files/Eclipse Adoptium/jdk-17.0.19.10-hotspot"
fi

exec "$MVN_CMD" "$@"
